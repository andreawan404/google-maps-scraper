# ── Browser ──────────────────────────────────────────────────
HEADLESS=true
BROWSER_TIMEOUT=30000

# ── Rate Limiting ─────────────────────────────────────────────
MIN_DELAY_SECONDS=2
MAX_DELAY_SECONDS=5

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///output/scraper.db

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=output/scraper.log

# ── Proxy (opsional) ─────────────────────────────────────────
# Format satu proxy: http://user:pass@host:port
# Format multiple (round-robin): proxy1,proxy2,proxy3
PROXY_LIST=

# ── Email Finder ──────────────────────────────────────────────
EMAIL_TIMEOUT_SECONDS=10
MAX_EMAIL_PER_SITE=3

# ── Retry ─────────────────────────────────────────────────────
MAX_RETRIES=3
